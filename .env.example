# --- Required in production ---
#
# `src/lib/env.ts` only falls back to the dev defaults below when
# NODE_ENV !== 'production'. A real production deploy that omits any of
# the variables below crashes at boot with a readable zod error (which
# the platform sees as a healthcheck failure) — *do not* take the dev values
# as a working production config.

# Canonical site URL. Used for the absolute links in magic-link sign-in
# emails. In production, set this to the app's public domain.
SITE_URL=http://localhost:3000

# >=32 char secret. Signs the session cookie.
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-32+-char-random-string

# SQLite file path. In production, point this at runtime-mounted persistent
# storage, for example DATABASE_URL=file:/data/app.db.
DATABASE_URL=file:./data/app.db

# Families — this JSON value IS the credential store AND the privacy boundary.
# There is no admin and no password. It is the single source of truth for:
#   1. the student sign-in allowlist (every "child" email),
#   2. the parent sign-in allowlist (every email in any "parents" array),
#   3. parent dashboard visibility — a parent sees ONLY the child in their own
#      family, never another family's child.
#
# Each entry is { "child": <email>, "parents": [<email>, ...] }. "parents" is
# optional and defaults to []; "parents": [] means a standalone child who can
# sign in and take exams but appears in NO parent dashboard. The expanded shape
# (pretty-printed) is:
#
#   [
#     { "child": "alex@example.com",
#       "parents": ["pat@example.com", "morgan@example.com"] },         # parent pair
#     { "child": "sam@example.com",  "parents": ["sam.parent@example.com"] },
#     { "child": "jess@example.com", "parents": [] }                    # standalone child
#   ]
#
# Rules (parsed strictly — ambiguity is rejected at boot): a "child" must be
# unique across families; an email can't be both a child and a parent; a parent
# can't appear in more than one family (the dashboard shows one child today).
#
# Behaviour: empty/unset FAMILIES fails closed (nobody can sign in); malformed
# JSON or an invalid email fails boot with a readable error. A parent can enter
# "student mode" to take exams themselves, but those attempts persist under the
# parent's own account — the child's record is owned structurally by users.id and
# is never reassigned. Sign-in always shows "Check your inbox" even for
# non-configured emails (no enumeration) — so no email arriving usually means the
# address isn't configured.
#
# Renaming a child's email later is a config change, not a DB migration —
# `exam_attempts` / `exam_sessions` are owned by users.id, so as long as a
# "child" email here exactly matches that child's existing users.email, the
# same row resolves and all history stays visible.
#
# Set FAMILIES as a SINGLE-LINE JSON string (multiline values are fragile across
# shells, hosting-provider UIs, dotenv parsing, and copy/paste):
FAMILIES='[{"child":"student@example.com","parents":["parent@example.com"]}]'

# Resend API key + verified From: address. Set to "test" locally to write
# emails to tests/.tmp/outbox/<id>.json instead of sending them.
RESEND_API_KEY=test
RESEND_FROM=Examify <onboarding@resend.dev>

# Anthropic API key for free-text grading. Set to "test" locally to use a
# deterministic full-score stub instead of calling the API (no network).
ANTHROPIC_API_KEY=test

# Cloudflare Turnstile site/secret pair. For local development, the
# Cloudflare dummy keys always pass:
#   site:   1x00000000000000000000AA
#   secret: 1x0000000000000000000000000000000AA
# For always-fail testing, use 2x* variants:
#   site:   2x00000000000000000000AB
#   secret: 2x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# --- Always optional ---

# When PLAUSIBLE_DOMAIN is set, the analytics script renders. Otherwise it
# stays off (no third-party traces in dev by default).
# PLAUSIBLE_DOMAIN=examify.example.com
# PLAUSIBLE_SRC=https://plausible.io/js/script.js

# Sign-in rate-limit override. A single per-IP bucket for every magic-link
# request (uniform threshold, so it can't reveal which emails already exist).
# Default: 10 per 1h per IP.
# RATE_LIMIT_SIGNIN_MAX=10
# RATE_LIMIT_SIGNIN_WINDOW_MS=3600000

# Cookie name override (rarely needed).
# SESSION_COOKIE_NAME=__Host-examify_session
